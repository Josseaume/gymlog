# Mot de passe d'accès à l'app (à définir dans Vercel > Settings > Environment Variables,
# ou dans .env.local pour le dev avec `vercel dev`)
GYM_PASSWORD=change-moi

# Fourni automatiquement par l'intégration Vercel Postgres (Neon) :
# POSTGRES_URL=...

# Fourni automatiquement par l'intégration Vercel Blob (photos de progression) :
# BLOB_READ_WRITE_TOKEN=...
